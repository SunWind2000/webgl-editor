{
  "name": "webgl-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm -r --filter @webgl-editor/ui --filter @webgl-editor/demo --filter playground build",
